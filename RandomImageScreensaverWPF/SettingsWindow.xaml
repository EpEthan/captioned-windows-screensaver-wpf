<Window x:Class="RandomImageScreensaverWPF.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RandomImageScreensaverWPF"
        mc:Ignorable="d"
        Title="SettingsWindow" Height="450" Width="800">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Image Directory Path -->
        <Label Grid.Row="0" Content="Image Directory Path:" FontWeight="Bold" Foreground="#333333"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5,0,15">
            <TextBox x:Name="PathTextBox" Width="300" IsReadOnly="True" Padding="5" 
                     Background="#F0F0F0" BorderBrush="#CCCCCC" BorderThickness="1"/>
            <Button Content="Browse..." Margin="10,0,0,0" Width="100" Padding="5" 
                    Click="BrowseButton_Click" Background="#4CAF50" Foreground="White" />
        </StackPanel>

        <!-- Interval Slider -->
        <Label Grid.Row="2" x:Name="IntervalLabel" Content="Change Interval: 10 seconds" FontWeight="Bold" Foreground="#333333"/>
        <Slider Grid.Row="3" x:Name="IntervalSlider" 
                Minimum="2" Maximum="60" Value="5" 
                TickPlacement="BottomRight" TickFrequency="1" IsSnapToTickEnabled="True"
                Margin="0,5,0,15"
                ValueChanged="IntervalSlider_ValueChanged"/>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" Margin="0,0,10,0" Width="80" Padding="8" 
                    Click="SaveButton_Click" Background="#2196F3" Foreground="White" />
            <Button Content="Cancel" Width="80" Padding="8" 
                    Click="CancelButton_Click" Background="#F44336" Foreground="White" />
        </StackPanel>
    </Grid>

    <Window.Resources>
        <!-- Simple button style for a modern look -->
        <Style x:Key="FlatButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{Binding RelativeSource={RelativeSource Self}, Path=Background.Color, Converter={StaticResource DarkenColorConverter}, ConverterParameter='0.8'}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Simple Color Converter (Need to define this in a real project, mocking for preview) -->
        <!-- <local:DarkenColorConverter x:Key="DarkenColorConverter"/> -->
    </Window.Resources>
</Window>
