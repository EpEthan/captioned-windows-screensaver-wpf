<Window x:Class="RandomImageScreensaverWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RandomImageScreensaverWPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Image x:Name="PhotoDisplay" RenderTransformOrigin="0.5,0.5" HorizontalAlignment="Center" Height="103" VerticalAlignment="Center" Width="100" Stretch="Uniform" Grid.RowSpan="1" Grid.ColumnSpan="1">
            <Image.RenderTransform>
                <ScaleTransform ScaleX="1.0" ScaleY="1.0" />
            </Image.RenderTransform>
        </Image>

        <Grid>
            
        </Grid>
    </Grid>
</Window>
